@page "/"

<PageTitle>Home</PageTitle>

<section class="pagina-inicial">
    <section class="secao-banner">
        <div class="banner-principal">
            <p class="subtitulo-banner">Portfólio do Manel / João G / Otávio / Vinícius</p>
            <h1 class="titulo-banner">Bem-vindo ao nosso espaço</h1>
            <p class="texto-banner">
                Aqui você encontra um resumo da nossa história, do nosso currículo e das formas de contato.
            </p>
        </div>
    </section>

    <section class="secao-destaques" id="destaques" aria-label="Destaques do site">
        <article class="cartao-destaque cartao-claro">
            <span class="numero-destaque">01</span>
            <h2>Nossa história</h2>
            <p>
                Aqui contamos um pouco sobre quem somos, nossos interesses e nossa trajetória.
            </p>
            <a href="/historia">Conhecer percurso</a>
        </article>

        <article class="cartao-destaque cartao-escuro">
            <span class="numero-destaque">02</span>
            <h2>Nosso currículo</h2>
            <p>
                Destaque das competências, experiências e projetos desenvolvidos pelo grupo.
            </p>
            <a href="/curriculo">Ver experiências</a>
        </article>

        <article class="cartao-destaque cartao-destaque-contato" id="contato">
            <span class="numero-destaque">03</span>
            <h2>Entre em contato</h2>
            <p>
                Um espaço para comunicação, parcerias e oportunidades profissionais.
            </p>
            <a href="/contato">Iniciar conversa</a>
        </article>
    </section>
</section>